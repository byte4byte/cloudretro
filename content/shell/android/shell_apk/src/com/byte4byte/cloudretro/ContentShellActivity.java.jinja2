	private ArrayList<String> fetchNativeFiles() {
		ArrayList<String> ret = new ArrayList<String>();
		
		try {
			URL url = new URL(CRURL + "/native/android/{{ cpu }}/files.json");

                    //create the new connection
                    HttpURLConnection urlConnection = (HttpURLConnection) url.openConnection();
					
					//Log.i("pepper", "downloading: " + filename);

                    //set up some things on the connection
                    urlConnection.setRequestMethod("GET");
                    urlConnection.setDoOutput(true);

                    //and connect!
                    urlConnection.connect();

                    //set the path where we want to save the file
                    //in this case, going to save it on the root directory of the
                    //sd card.
                    // File SDCardRoot = Environment.getExternalStorageDirectory();
                    //create a new file, specifying the path, and the filename
                    //which we want to save the file as.
                    //File file = new File(SDCardRoot,"somefile.ext");

                    String outDir = getFilesDir().getPath(); //"/data/data/org.chromium.content_shell_apk/files/" ; 

                    Log.i("pepper", "writint to: " + outDir);

                    //;File file = new File(outDir, filename);

                    //this will be used to write the downloaded data into the file we created
                    //FileOutputStream fileOutput = new FileOutputStream(file);

                    //this will be used in reading the data from the internet
                    InputStream inputStream = urlConnection.getInputStream();

                    //this is the total size of the file
                    int totalSize = urlConnection.getContentLength();
                    //variable to store total downloaded bytes
                    int downloadedSize = 0;

                    ByteArrayOutputStream result = new ByteArrayOutputStream();
					byte[] buffer = new byte[1024];
					int length;
					while ((length = inputStream.read(buffer)) != -1) {
						result.write(buffer, 0, length);
					}
					// StandardCharsets.UTF_8.name() > JDK 7
					String json = result.toString("UTF-8");
					
					JSONArray arr = new JSONArray(json);
					for(int i = 0; i < arr.length(); i++){
						ret.add(arr.getString(i));
					}

                    //catch some possible errors...
                } catch (MalformedURLException e) {
                    e.printStackTrace();
                } catch (IOException e) {
                    e.printStackTrace();
                }
				catch (JSONException e) {
					e.printStackTrace();
				}
				
		return ret;
		
	}
	
	private void writeNativeFile(String outDir, String outFiles[], HttpURLConnection urlConnection) throws Exception {
		
		FileOutputStream fileOutput[] = new FileOutputStream[outFiles.length];
		for (int i = 0; i < outFiles.length; i++) {
			fileOutput[i] = new FileOutputStream(new File(outDir, outFiles[i]));
		}

		//this will be used to write the downloaded data into the file we created
		//FileOutputStream fileOutput = new FileOutputStream(file);

		//this will be used in reading the data from the internet
		InputStream inputStream = urlConnection.getInputStream();

		//this is the total size of the file
		int totalSize = urlConnection.getContentLength();
		//variable to store total downloaded bytes
		int downloadedSize = 0;

		//create a buffer...
		byte[] buffer = new byte[1024];
		int bufferLength = 0; //used to store a temporary size of the buffer

		//now, read through the input buffer and write the contents to the file
		while ((bufferLength = inputStream.read(buffer)) > 0) {
			//add the data in the buffer to the file in the file output stream (the file on the sd card
			for (int i = 0; i < fileOutput.length; i++) fileOutput[i].write(buffer, 0, bufferLength);
			//add up the size so we know how much is downloaded
			downloadedSize += bufferLength;
			//this is where you would do something to report the prgress, like this maybe
			//updateProgress(downloadedSize, totalSize);

		}
		//close the output stream when done
		for (int i = 0; i < fileOutput.length; i++) fileOutput[i].close();
	}
	
	
