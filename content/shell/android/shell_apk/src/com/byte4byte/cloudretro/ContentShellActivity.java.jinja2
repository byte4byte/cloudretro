	public class WiimoteWriteThread extends Thread {

        int bufferSize = 1024;
        byte[] buffer;
        int bytesRead;
        int totalBytesRead;
        int posOffset;
        LocalServerSocket server;
        LocalSocket receiver;
        InputStream input;
        private volatile boolean stopThread;
		public String SOCKET_ADDRESS = "my.local.socket.address";

        public WiimoteWriteThread() {
            //toastIt(" +++ Begin of localServerSocket() +++ ");
            buffer = new byte[bufferSize];
            bytesRead = 0;
            totalBytesRead = 0;
            posOffset = 0;

            try {
                server = new LocalServerSocket(SOCKET_ADDRESS);
            } catch (IOException e) {
                // TODO Auto-generated catch block
                toastIt("The LocalServerSocket created failed !!!");
                e.printStackTrace();
            }

            stopThread = false;
        }

		@Override
        public void run() {            
				int cnt[] = {0,0,0,0};
           // toastIt(" +++ Begin of run() +++ ");
                while (!stopThread) {

                    if (null == server){
                        //toastIt( "The LocalServerSocket is NULL !!!");
                        stopThread = true;
                        break;
                    }

                    try {
                       // toastIt("LocalServerSocket begins to accept()");
                        receiver = server.accept();
                    } catch (IOException e) {
                        // TODO Auto-generated catch block
                        toastIt("LocalServerSocket accept() failed !!!");
                        e.printStackTrace();
                        continue;
                    }                   

                    try {
                        input = receiver.getInputStream();
                    } catch (IOException e) {
                        // TODO Auto-generated catch block
                       toastIt( "getInputStream() failed !!!");
                        e.printStackTrace();
                        continue;
                    }

					//toastIt("The client connect to LocalServerSocket");

					
                    while (receiver != null) {

					//Log.i(TAG, "reading: + " + posOffset + " | " + totalBytesRead);
					
					//if (posOffset < 4) {
                        try {
							Log.i(TAG, "reading: " + posOffset + ", " + (bufferSize - totalBytesRead));
                           bytesRead = input.read(buffer, posOffset,
                                    (bufferSize - totalBytesRead));
							//Log.i(TAG, "readb: " +bytesRead);
                        } catch (IOException e) {
                            // TODO Auto-generated catch block
                           toastIt("There is an exception when reading socket");
                            e.printStackTrace();
                            break;
                        }
						Log.i(TAG, "read: " + bytesRead);
						
						if (bytesRead >= 0) {
                           // Log.d(TAG, "Receive data from socket, bytesRead = "
                           //         + bytesRead);
                            posOffset += bytesRead;
                            totalBytesRead += bytesRead;
                        }
						else break;
						
					//}
						if (posOffset < 4) continue;
						
						for(;;) {
							
							if (posOffset < 4) break;
						
						byte[] lenarr = { buffer[3], buffer[2], buffer[1], buffer[0] };
						ByteBuffer lenwrapped = ByteBuffer.wrap(lenarr); // big-endian by default
						int size = lenwrapped.getInt();
						
						Log.i(TAG, "size: " + size);
						
						if (posOffset < size + 4) break;
						
						
						
						byte[] arr = { buffer[7], buffer[6], buffer[5], buffer[4] };
						
						ByteBuffer wrapped = ByteBuffer.wrap(arr); // big-endian by default
						int player = wrapped.getInt(); // 1
						
						Log.i(TAG, "player: " + player);
						
						
						WiimoteAdapter.Output(player, buffer, 8, size-4);
						
						//if (++cnt[player] >= 4) wiimote_inited[player] = true;
						
						Log.i(TAG, "Wrote: " + (size-4));
						
						//if (true) {
						//	posOffset = 0;
                        //    totalBytesRead = 0;
						//	continue;
						//}
						
						//posOffset++;
						if (posOffset > size+4) {
							
							Log.i("ECWRITE", "Wrapped: " + posOffset + " | " + (size+4));
							
							//System.arraycopy(b1, bytes, result, 0, bytes);
							//public static void arraycopy(Object src, int srcPos, Object dest, int destPos, int length)
							//System.arraycopy(buffer, size+4, buffer, 0, 
							for (int i = 0; i < posOffset-(size+4); i++) {
								buffer[i] = buffer[i+size+4];
							}
							totalBytesRead = posOffset-(size+4);
							posOffset = posOffset-(size+4);
							
							
							
						}							
						else {
							posOffset = 0;
                            totalBytesRead = 0;
							Log.i("ECWRITE", "Complete");
						}
						
						}

                       /* if (bytesRead >= 0) {
                            toastIt("Receive data from socket, bytesRead = "
                                    + bytesRead);
                            posOffset += bytesRead;
                            totalBytesRead += bytesRead;
                        }

                        if (totalBytesRead == bufferSize) {
                            toastIt("The buffer is full !!!");
                            String str = new String(buffer);
                            toastIt("The context of buffer is : " + str);

                            bytesRead = 0;
                            totalBytesRead = 0;
                            posOffset = 0;
                        }*/

                    }
					
				//}
                    Log.i(TAG, "The client socket is NULL !!!");
                }
                Log.i(TAG, "The LocalSocketServer thread is going to stop !!!");
                if (receiver != null){
                    try {
                        receiver.close();
                    } catch (IOException e) {
                        // TODO Auto-generated catch block
                        e.printStackTrace();
                    }
                }
                if (server != null){
                    try {
                        server.close();
                    } catch (IOException e) {
                        // TODO Auto-generated catch block
                        e.printStackTrace();
                    }
                }
        }

        public void setStopThread(boolean value){
            stopThread = value;
            Thread.currentThread().interrupt(); // TODO : Check
        }

    }
	
