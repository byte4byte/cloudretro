    public static float round(float value, int scale) {
        int pow = 10;
        for (int i = 1; i < scale; i++) {
            pow *= 10;
        }
        float tmp = value * pow;
        float tmpSub = tmp - (int) tmp;
    
        return ( (float) ( (int) (
                value >= 0
                ? (tmpSub >= 0.5f ? tmp + 1 : tmp)
                : (tmpSub >= -0.5f ? tmp : tmp - 1)
                ) ) ) / pow;
    
        // Below will only handles +ve values
        // return ( (float) ( (int) ((tmp - (int) tmp) >= 0.5f ? tmp + 1 : tmp) ) ) / pow;
    }

    @Override
    public boolean dispatchGenericMotionEvent(MotionEvent ev) {

        if (! g_wiimote_threads_created) return super.dispatchGenericMotionEvent(ev);

        // if (event.getAction() == KeyEvent.ACTION_DOWN) {

        //callJS("printStr('" + ev.getAxisValue(MotionEvent.AXIS_X) +" | " + ev.getAxisValue(MotionEvent.AXIS_Y )+ "');");

        /* int actionCode = ev.getAction() & ev.ACTION_MASK;
            if (actionCode == MotionEvent.ACTION_UP || actionCode == MotionEvent.ACTION_CANCEL) {
                callJS("setNavKeyUp(40);");
                callJS("setNavKeyUp(38);");
                callJS("setNavKeyUp(37);");
                callJS("setNavKeyUp(39);");
            }
            else if (actionCode == MotionEvent.ACTION_DOWN || actionCode == MotionEvent.ACTION_MOVE) {
*/
	//Toast.makeText(ctx, "Generic Motion",  Toast.LENGTH_SHORT).show();
	
		int idx = getDeviceIndex(ev.getDeviceId());
		boolean newidx = false;
	
		GamepadValues gvals;
		if (gpad_vals.containsKey(idx)) {
			gvals = gpad_vals.get(idx);
		}
		else {
			gvals = new GamepadValues();
			gpad_vals.put(idx, gvals);
			newidx = true;
		}
	
		
	
		float lx = round(ev.getAxisValue(MotionEvent.AXIS_X), 6);
		float ly = round(ev.getAxisValue(MotionEvent.AXIS_Y), 6);
		float rx = round(ev.getAxisValue(MotionEvent.AXIS_Z), 6);
		float ry = round(ev.getAxisValue(MotionEvent.AXIS_RZ), 6);
		float ltrig = round(ev.getAxisValue(MotionEvent.AXIS_LTRIGGER), 6);
		float rtrig = round(ev.getAxisValue(MotionEvent.AXIS_RTRIGGER), 6);
		float hatx = round(ev.getAxisValue(MotionEvent.AXIS_HAT_X), 6);
		float haty = round(ev.getAxisValue(MotionEvent.AXIS_HAT_Y), 6);

        float left_stick_x = round(cleanMotionValues(lx), 6);
        float left_stick_y = round(cleanMotionValues(ly), 6);
        float right_stick_x = round(cleanMotionValues(rx), 6);
        float right_stick_y = round(cleanMotionValues(ry), 6);
        float left_trigger = ltrig;
        float right_trigger = rtrig;
        boolean dpad_down = haty > dpadThreshold;
        boolean dpad_up = haty < -dpadThreshold;
        boolean dpad_right = hatx > dpadThreshold;
        boolean dpad_left = hatx < -dpadThreshold;
		
		left_trigger = cleanMotionValues(left_trigger);
		right_trigger = cleanMotionValues(right_trigger);
		
		boolean l = Math.abs(left_trigger) >= 0.5f;
		boolean r = Math.abs(right_trigger )>= 0.5f;

        if (dpad_left || left_stick_x < 0 || right_stick_x < 0) {
            if (! gvals.navleft || newidx) nav_keydown(37, idx);
			gvals.navleft = true;
        } else {
            if (gvals.navleft || newidx) nav_keyup(37, idx);
			gvals.navleft = false;
        }
        if (dpad_right || left_stick_x > 0 || right_stick_x > 0) {
            if (! gvals.navright || newidx) nav_keydown(39, idx);
			gvals.navright = true;
        } else {
            if (gvals.navright || newidx) nav_keyup(39, idx);
			gvals.navright = false;

        }
        if (dpad_up || left_stick_y < 0 || right_stick_y < 0) {
            if (! gvals.navup || newidx) nav_keydown(38, idx);
			gvals.navup = true;
        } else {
            if (gvals.navup || newidx) nav_keyup(38, idx);
			gvals.navup = false;
        }
        if (dpad_down || left_stick_y > 0 || right_stick_y > 0) {
            if (!gvals.navdown || newidx) nav_keydown(40, idx);
			gvals.navdown = true;
        } else {
            if (gvals.navdown || newidx) nav_keyup(40, idx);
			gvals.navdown = false;
        }
		
		
		if (ltrig != gvals.LTRIG || newidx) native_axis("LTRIG", ltrig, idx);
		if (rtrig != gvals.RTRIG || newidx) native_axis("RTRIG", rtrig, idx);
		if (lx != gvals.LX || newidx) native_axis("LX", lx, idx);
		if (ly != gvals.LY || newidx) native_axis("LY", ly, idx);
		if (rx != gvals.RX || newidx) native_axis("RX", rx, idx);
