    @Override
    public boolean dispatchKeyEvent(KeyEvent event) {
		//toast("KeyCode: " + event.getKeyCode());
        //Toast.makeText(ctx, "KeyCode: " + event.getKeyCode(),  Toast.LENGTH_SHORT).show();
        
        if (! g_wiimote_threads_created) return super.dispatchKeyEvent(event);
		
		int idx = getDeviceIndex(event.getDeviceId());
		
		if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
			native_keydown(event.getKeyCode(), idx);
		} else if (event.getAction() == KeyEvent.ACTION_UP) {
			native_keyup(event.getKeyCode(), idx);
		}
        
        if (event.getKeyCode() == KeyEvent.KEYCODE_DPAD_DOWN) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(40, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(40, idx);
            }
            //return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_DPAD_LEFT) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(37, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(37, idx);
            }
            // return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_DPAD_RIGHT) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(39, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(39, idx);
            }
            //return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_DPAD_UP) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(38, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(38, idx);
            }
            //return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_BACK) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(-1000, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(-1000, idx);
            }
            return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_BUTTON_A) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(13, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(13, idx);
            }
            //return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_BUTTON_X) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(32, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(32, idx);
            }
            //return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_BUTTON_B) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(27, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(27, idx);
            }
            //return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_BUTTON_Y) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(46, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(46, idx);
            }
            //return true;
        }
        else if (event.getKeyCode() == KeyEvent.KEYCODE_MENU) {
            if (event.getAction() == KeyEvent.ACTION_DOWN && event.getRepeatCount() == 0) {
                nav_keydown(-1001, idx);
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                nav_keyup(-1001, idx);
            }

            return true;
            //return super.dispatchKeyEvent(event);
        }
		else {
			
			//callJS("setNavKeyDown(" + event.getKeyCode() + ");");
		}
        return super.dispatchKeyEvent(event);
    }


